# Adotme API - Environment variables template
#
# Copy this file to .env and fill in your own values. .env is gitignored.
# Never commit secrets to the repository.

# ----- Database (MySQL) -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=adoteMe
DB_USER=root
DB_PASSWORD=

# ----- Security -----
# Random string used to sign JWT tokens. Use a 32+ character secret in production.
JWT_SECRET=

# ----- TheCatAPI -----
# Free signup at https://thecatapi.com/ (used to fetch breed metadata for cats)
THECATAPI_BASE_URL=https://api.thecatapi.com/v1
THECATAPI_API_KEY=

# ----- Cloudinary (image uploads) -----
# Free tier at https://cloudinary.com/ — get credentials from dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Email (used for password reset) -----
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
